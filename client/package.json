{
  "name": "rmm-client",
  "version": "1.0.0",
  "description": "RMM Windows Client Worker",
  "main": "src/client.js",
  "scripts": {
    "start": "node src/client.js",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/rmm-client.exe"
  },
  "bin": {
    "rmm-client": "./src/client.js"
  },
  "dependencies": {
    "node-windows": "^1.0.0-beta.8",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "src/winvnc.exe"
    ]
  }
}
