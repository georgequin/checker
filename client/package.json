{
  "name": "rmm-client",
  "version": "1.0.0",
  "description": "RMM Windows Client Worker",
  "main": "src/client.js",
  "scripts": {
    "start": "node src/client.js",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/rmm-client.exe",
    "build:install-script": "pkg install-service.js --targets node18-win-x64 --output dist/install-service.exe",
    "build:uninstall-script": "pkg uninstall-service.js --targets node18-win-x64 --output dist/uninstall-service.exe",
    "build:all": "npm run build:exe && npm run build:install-script && npm run build:uninstall-script"
  },
  "bin": {
    "rmm-client": "./src/client.js"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "node-windows": "^1.0.0-beta.8",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "src/winvnc.exe"
    ]
  }
}
